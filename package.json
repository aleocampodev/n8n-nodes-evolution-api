{
	"name": "n8n-nodes-evolution-api",
	"version": "0.1.0",
	"description": "Professional n8n node for generic and native WhatsApp automation using Evolution API. Features declarative routing and a future-proof Custom API Request architecture.",
	"license": "MIT",
	"homepage": "",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Ale",
		"email": "ale@example.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Ale/n8n-nodes-evolution-api.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/EvolutionApiApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/EvolutionApi/EvolutionApi.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
